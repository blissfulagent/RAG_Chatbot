{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:chroma": "powershell -NoProfile -Command \"$env:Path = ($env:Path -split ';' | Where-Object { $_ -notlike '*node_modules*' }) -join ';'; chroma run --host localhost --port 8000 --path ./data/chroma\"",
    "dev:all": "concurrently -n chroma,next -c yellow,blue \"npm:dev:chroma\" \"npm:dev\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@langchain/core": "^1.2.1",
    "@langchain/google-genai": "^2.2.0",
    "@langchain/langgraph": "^1.4.7",
    "@langchain/langgraph-checkpoint-sqlite": "^1.0.3",
    "better-sqlite3": "^12.11.1",
    "chromadb": "^3.4.3",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.9",
    "pdf-parse": "^2.4.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.3",
    "drizzle-kit": "^0.31.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.19.4",
    "typescript": "^5"
  }
}
